# =============================================
# 🔒 BACKEND - .gitignore (Safety File)
# =============================================

# --- Environment Variables (NEVER commit these!) ---
.env
.env.local
.env.development
.env.production
.env.staging
.env.test
*.env

# --- Node.js Dependencies ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json

# --- Logs ---
logs/
*.log
combined.log
error.log

# --- Database Files (local) ---
*.sqlite
*.sqlite3
*.db

# --- SSL / Certificates (sensitive!) ---
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx

# --- Secrets & API Keys ---
secrets.json
credentials.json
serviceAccountKey.json
*.secret

# --- OS Files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editor / IDE ---
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Build / Cache ---
dist/
build/
.cache/
tmp/
temp/
